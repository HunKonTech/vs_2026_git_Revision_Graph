### Windows
# Windows thumbnail cache files
Thumbs.db

# Folder config file
[Dd]esktop.ini

# Recycle Bin used on file shares
$RECYCLE.BIN/

# Windows shortcuts
*.lnk

### Linux
# Backup files
*~

# Temporary files from deleted open files
.fuse_hidden*

# KDE directory preferences
.directory

# Linux trash folder
.Trash-*

# NFS temporary files
.nfs*

### C#
# Build results
[Bb]in/
[Oo]bj/

# Visual Studio cache/options directory
.vs/

# User-specific files
*.suo
*.user

# Debug symbols
*.pdb

# NuGet Packages
*.nupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/

# .NET build artifacts
artifacts/

# Publish output
publish/

### Node / TypeScript
# The C# rule above (**/[Pp]ackages/*) would swallow our TS source workspace.
# Re-include the packages tree first, then re-ignore build/dep output below.
!packages/
!packages/**

node_modules/
dist/
out/
*.tsbuildinfo
*.vsix
.claude

# Generated copies of the shared web renderer bundle
vscode/media/
vs/webview/main.js
vs/webview/main.css

# Generated LICENSE copy for VS Code packaging
vscode/LICENSE
github-actions-org-runner-selection-spec.md alias
.vscode
temp
