{
  "name": "rev-graph-vscode",
  "displayName": "Revision Graph for Git",
  "description": "TortoiseSVN-style revision graph for Git: commits, local & remote branches, and tags as connected boxes. Right-click a commit to create a branch from it.",
  "version": "0.1.0",
  "publisher": "benkoncsik",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["SCM Providers", "Visualization"],
  "repository": {
    "type": "git",
    "url": "https://github.com/HunKonTech/git_Revision_Graph.git"
  },
  "license": "SEE LICENSE IN LICENSE",
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "revGraph.show",
        "title": "Open Revision Graph",
        "category": "Git Revision Graph",
        "icon": "$(git-branch)"
      },
      {
        "command": "revGraph.refresh",
        "title": "Refresh Revision Graph",
        "category": "Git Revision Graph",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "revGraphContainer",
          "title": "Revision Graph",
          "icon": "icons/revision-graph.svg"
        }
      ]
    },
    "views": {
      "revGraphContainer": [
        {
          "id": "revGraph.launchView",
          "name": "Git Revision Graph",
          "icon": "icons/revision-graph.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "revGraph.launchView",
        "contents": "%revGraph.welcome.contents%"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "revGraph.show",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ],
      "view/title": [
        {
          "command": "revGraph.show",
          "group": "navigation",
          "when": "view == revGraph.launchView",
          "icon": "$(git-branch)"
        }
      ]
    },
    "keybindings": [
      {
        "command": "revGraph.show",
        "key": "ctrl+alt+g",
        "mac": "ctrl+alt+g",
        "when": "!terminalFocus"
      }
    ],
    "configuration": {
      "title": "Git Revision Graph",
      "properties": {
        "revGraph.maxCommits": {
          "type": "number",
          "default": 1000,
          "description": "Maximum number of commits to load into the graph."
        }
      }
    }
  },
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "vscode:prepublish": "node build.mjs"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0"
  },
  "dependencies": {
    "@rev-graph/protocol": "0.1.0"
  }
}
